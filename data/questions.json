":[{"text":"Smaller temps improve efficiency","correct":true},{"text":"Larger temps improve efficiency","correct":false},{"text":"No effect","correct":false},{"text":"Lower temps reduce costs","correct":true}]}]},{"id":"troubleshooting","name":"Troubleshooting","icon":"🔍","questions":[{"id":"q16","question":"Not cooling adequately cause?","type":"single","answers":[{"text":"Refrigerant leak/low charge","correct":true},{"text":"Water too cold","correct":false},{"text":"Room too warm","correct":false},{"text":"Compressor fast","correct":false}]},{"id":"q17","question":"Diagnose refrigerant leak steps?","type":"multiple","answers":[{"text":"Check pressure/temp","correct":true},{"text":"Electronic leak detectors","correct":true},{"text":"Inspect oil traces","correct":true},{"text":"Increase setpoint","correct":false}]},{"id":"q18","question":"Compressor overload indicates?","type":"single","answers":[{"text":"High discharge pressure and amperage","correct":true},{"text":"Low discharge pressure","correct":false},{"text":"Normal amperage low cooling","correct":false},{"text":"Slow startup","correct":false}]},{"id":"q19","question":"High suction pressure?","type":"multiple","answers":[{"text":"Expansion device block","correct":false},{"text":"Flooded evaporator","correct":true},{"text":"Broken expansion valve","correct":true},{"text":"Low refrigerant","correct":false}]},{"id":"q20","question":"Chiller alarm first action?","type":"single","answers":[{"text":"Check alarm code and diagnostics","correct":true},{"text":"Shut down immediately","correct":false},{"text":"Increase setpoint","correct":false},{"text":"Call technician only","correct":false}]}]}]}