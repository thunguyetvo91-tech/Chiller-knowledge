{"categories":[{"id":"basics","name":"Chiller Basics","icon":"❄️","questions":[{"id":"q1","question":"What is the primary function of a chiller?","type":"single","answers":[{"text":"Remove heat from liquid and transfer it","correct":true},{"text":"Add heat to liquid","correct":false},{"text":"Maintain pressure","correct":false},{"text":"Filter water","correct":false}]},{"id":"q2","question":"Which are types of chillers?","type":"multiple","answers":[{"text":"Centrifugal","correct":true},{"text":"Screw","correct":true},{"text":"Piston","correct":false},{"text":"Reciprocating","correct":true}]},{"id":"q3","question":"Typical chilled water temperature range?","type":"single","answers":[{"text":"32-45°F (0-7°C)","correct":true},{"text":"50-65°F","correct":false},{"text":"70-85°F","correct":false},{"text":"20-30°F","correct":false}]},{"id":"q4","question":"What is COP (Coefficient of Performance)?","type":"single","answers":[{"text":"Ratio of cooling capacity to power input","correct":true},{"text":"Max temperature","correct":false},{"text":"Operating pressure","correct":false},{"text":"Noise level","correct":false}]},{"id":"q5","question":"Common modern refrigerants?","type":"multiple","answers":[{"text":"R-134a","correct":true},{"text":"R-410A","correct":true},{"text":"R-12","correct":false},{"text":"R-744","correct":true}]}]},{"id":"maintenance","name":"Maintenance","icon":"🔧","questions":[{"id":"q6","question":"How often clean chiller tubes?","type":"single","answers":[{"text":"Annually or when fouling detected","correct":true},{"text":"Every 5 years","correct":false},{"text":"Monthly","correct":false},{"text":"Never","correct":false}]},{"id":"q7","question":"Signs of refrigerant leak?","type":"multiple","answers":[{"text":"Reduced cooling capacity","correct":true},{"text":"Increased compressor amperage","correct":true},{"text":"Higher discharge pressure","correct":true},{"text":"Lower water temperature","correct":false}]},{"id":"q8","question":"Purpose of condenser?